import re

def answer_question(profile: dict, question: str) -> dict:
    """
    Analiza la pregunta y retorna una respuesta relevante basada en el perfil.
    """
    question_lower = question.lower()
    
    # Detectar idioma de la pregunta
    is_english = any(word in question_lower for word in ['what', 'who', 'where', 'when', 'how', 'tell me', 'describe'])
    lang = 'en' if is_english else 'es'
    
    answer = ""
    context_used = []
    found = False
    
    # Patrones de preguntas y respuestas (evaluar en orden de especificidad)
    
    # Salesforce específicamente
    if not found and any(word in question_lower for word in ['salesforce', 'crm', 'service cloud']):
        if lang == 'es':
            answer = "Mirel tiene certificaciones en Salesforce Administration, App Builder, Service Cloud y Salesforce AI Associate. Ha trabajado en automatización de procesos y diseño de flujos CRM en entornos empresariales."
        else:
            answer = "Mirel holds certifications in Salesforce Administration, App Builder, Service Cloud and Salesforce AI Associate. She has worked on process automation and CRM workflow design in business environments."
